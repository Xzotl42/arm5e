<div class="{{ cssClass }} arm5e-roll" autocomplete="off">
  <div class="roll-options">
    <div class="flexrow flex-group-center">
      <label class="">{{localize "arm5e.twilight.comprehension.roll"}}</label>
    </div>
    <div class="flexrow flex-group-center">
      <label class=""
        >{{localize "arm5e.sheet.intelligence"}} ({{ system.characteristics.int.value }})</label
      >
    </div>

    <div class="flexrow flex-group-center">
      <label class="">+</label>
    </div>
    {{#if rollInfo.twilight.enigma.score}}
    <div class="flexrow flex-group-center">
      <label class=""
        >{{lookup rollInfo.generic.txtOption 0}} ({{lookup rollInfo.generic.option 0}})</label
      >
      {{#if system.twilight.enigmaSpec}}
      <div class="flexrow flex-group-center">
        <label class=""
          >{{localize "arm5e.sheet.speciality"}} ({{ rollInfo.twilight.enigma.speciality }}) +
          1</label
        >
      </div>
      {{/if}}
    </div>
    <div class="flexrow flex-group-center">
      <label class="">+</label>
    </div>
    {{/if}}
    <div class="flexrow flex-group-center">
      <label class="flex03">{{localize "arm5e.sheet.modifier"}}</label>
      <input
        type="Number"
        name="rollInfo.modifier"
        value="{{ rollInfo.modifier }}"
        data-dtype="Number"
        class="SelectedModifier select-on-focus"
      />
    </div>

    <div class="flexcol flex-group-center">
      <label class=""
        ><img
          src="systems/arm5e/assets/ballSilver.png"
          title="Penetration"
          width="24"
          height="24"
          style="border: 0px"
      /></label>
    </div>
    <div class="flexrow flex-group-center">
      <label class="">{{localize "arm5e.generic.versus"}}</label>
    </div>

    <div class="flexrow flex-group-center">
      <label class="" style="font-size: 16pt">{{ system.twilight.complexity }}</label>
    </div>
  </div>
</div>
