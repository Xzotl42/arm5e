<div class="{{ cssClass }} arm5e-roll" autocomplete="off">
  {{log "this" this}}
  <div class="roll-options">
    <div class="flexrow flex-group-center" style="word-break: break-all">
      <label class="" style="font-size: 13pt; position: relative">{{ rollInfo.label }}</label>
    </div>
    {{> "systems/arm5e/templates/actor/parts/actor-voice-and-gestures.hbs" selection=rollInfo.selection id=_id}}
    <div class="flexrow flex-group-center">
      <label class="technique-label"
        >{{ rollInfo.magic.technique.label }} ({{ rollInfo.magic.technique.score }})</label
      >
      <label class="flex0"> + </label>
      <label class="form-label"
        >{{ rollInfo.magic.form.label }} ({{ rollInfo.magic.form.score }})</label
      >
      <a
        class="item-control advanced-req-roll flex0"
        title="Advanced Requistes"
        data-flavor="NPC"
        data-type="{{ rollInfo.type }}"
        data-itemId="{{ rollInfo.itemId }}"
        data-actorId="{{ _id }}"
        ><i class="fas fa-gavel fa-lg"></i
      ></a>
    </div>
    <div class="flexrow flex-group-center">
      <label class="" style="font-size: 12pt">+</label>
    </div>
    <div class="flexrow flex-group-center">
      <label class="flex03"
        >{{ localize system.charmetadata.sta.label }} ({{
          system.characteristics.sta.value
        }})</label
      >
      {{#unless (eq rollInfo.magic.masteryScore 0) }}
      <label class="flex0"> + </label>
      <label class="flex03"
        >{{localize "arm5e.sheet.mastery" }} ({{ rollInfo.magic.masteryScore }})</label
      >
      {{/unless}}
    </div>
    <div class="flexrow flex-group-center">
      <label class="">+</label>
    </div>
    <div class="flexrow flex-group-center">
      <label class="flex02" style="padding-right: 10px"
        >{{localize "arm5e.sheet.modifier" }}
      </label>
      <input
        type="number"
        name="rollInfo.modifier"
        value="{{ rollInfo.modifier }}"
        data-dtype="Number"
        class="SelectedModifier flex02 select-on-focus"
        style="width: 80px"
      />
    </div>
    <div class="flexrow flex-group-center">
      <label class="">+</label>
    </div>
    {{#if rollInfo.environment.aura.visible}}
    <div class="flexrow flex-group-center">
      <label class="flex03" style="padding-right: 10px"
        >{{localize "arm5e.sheet.levelAura"}}
      </label>
      <input
        type="number"
        name="rollInfo.environment.aura.modifier"
        value="{{ rollInfo.environment.aura.modifier }}"
        data-dtype="Number"
        class="SelectedAura flex02 select-on-focus"
      />
    </div>
    {{else}}
    <div class="flexrow flex-group-center">
      <label class="flex03" style="padding-right: 10px"
        >{{localize "arm5e.sheet.levelAura"}}
      </label>
      <input
        type="number"
        style="display: none"
        name="rollInfo.environment.aura.modifier"
        value="{{ rollInfo.environment.aura.modifier }}"
        data-dtype="Number"
        class="SelectedAura flex02 select-on-focus"
      />
      ???
    </div>
    {{/if}}
    <div class="flexrow flex-group-center">
      <label class="">+</label>
    </div>
    <div class="resource flexrow flex-group-center">
      <label class="" style="flex: 0.6">{{localize "arm5e.spell.applyFocus" }}</label>
      <input
        type="checkbox"
        name="rollInfo.magic.focus"
        {{checked
        rollInfo.magic.focus}}
        class="SelectedFocus"
      />
    </div>

    {{#if (eq rollInfo.magic.ritual true)}}
    <div class="flexrow flex-group-center">
      <label class="">+</label>
    </div>
    <div class="flexrow flex-group-center">
      <label class=""
        >{{localize "arm5e.skill.academic.artesLib" }} ({{
          system.laboratory.abilitiesSelected.artesLib.value
        }}) +
        {{localize
            "arm5e.skill.academic.philosophy" }}
        ({{ system.laboratory.abilitiesSelected.philosophy.value }})</label
      >
    </div>
    {{/if}}
    {{#unless (eq rollInfo.bonusesExtended 0) }}
    <div class="flexrow flex-group-center">
      <label class="">+</label>
    </div>
    <div class="flexrow flex-group-center clickable">
      <label class=" " data-hidden="activeEffects"
        >{{localize "arm5e.sheet.bonuses.label"}} ({{ rollInfo.bonusesExtended }})</label
      >
    </div>
    <div class="activeEffects hide">
      {{#unless (eq rollInfo.magic.bonus 0) }}
      <div class="flexrow flex-group-center">
        <label class="">+</label>
      </div>
      <div class="flexrow flex-group-center sub">
        <label class="">{{ rollInfo.magic.bonusDesc }} : {{ rollInfo.magic.bonus }}</label>
      </div>
      {{/unless}}
      {{#each rollInfo.activeEffects as |item id|}}
      <div class="flexrow flex-group-center">
        <label class="">+</label>
      </div>
      <div class="flexrow flex-group-center sub">
        <label class="">{{ item.label }} {{numberFormat item.value decimals=0 sign=true}}</label>
      </div>
      {{/each}}
    </div>
    {{/unless}}
    {{#each rollInfo.optionalBonuses as |optional|}}
    <div class="flexrow flex-group-center sub">
      <div class="modifier">+</div>
      <label class="">{{ optional.name }} ({{ optional.bonus }})</label
      ><input
        type="checkbox"
        name="{{ optional.name }}"
        {{checked
        optional.active}}
        class="SelectedOptional{{@index}} flex01"
      />
    </div>
    {{/each}}
    <div class="flexrow flex-group-center">
      {{#unless (eq system.fatigueTotal 0) }}
      <div class="flexrow flex-group-center">
        <label class=""
          >+ {{localize "arm5e.sheet.fatigue.label"}} ({{ system.fatigueTotal }})</label
        >
      </div>
      {{/unless}}
      {{#unless (eq system.penalties.wounds.total  0) }}
      <div class="flexrow flex-group-center">
        <label class=""
          >+ {{localize "arm5e.sheet.wounds"}} ({{ system.penalties.wounds.total }})</label
        >
      </div>
      {{/unless}}
      {{#unless (eq system.combat.overload 0) }}
      <div class="flexrow flex-group-center">
        <label class=""
          >- {{localize "arm5e.sheet.encumbrance"}} ({{ system.combat.overload }})</label
        >
      </div>
      {{/unless}}
    </div>

    <div class="flexcol flex-group-center">
      <label class=""
        ><img
          src="systems/arm5e/assets/icons/Icon_Details_option1.png"
          title="Penetration"
          width="24"
          height="24"
          style="border: 0px"
      /></label>
    </div>
    {{> "systems/arm5e/templates/roll/parts/penetration-options.hbs" }}
  </div>
  <!-- HIDDEN PART -->
  <div hidden>
    {{#each rollInfo.technique-req as |technique key|}}
    {{#with (lookup @root.config.magic.techniques key)~}}
    <input
      type="checkbox"
      name="rollInfo.magic.technique-req.{{ key }}"
      class="Selected{{ label }}"
      {{checked
      technique}}
    />
    {{/with}}
    {{/each}}
    {{#each rollInfo.form-req as |form key|}}
    {{#with (lookup @root.config.magic.forms key)~}}
    <input
      type="checkbox"
      name="rollInfo.magic.form-req.{{ key }}"
      class="Selected{{ label }}"
      {{checked
      form}}
    />
    {{/with}}
    {{/each}}
  </div>
</div>
