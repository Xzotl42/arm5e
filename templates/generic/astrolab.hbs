<section class="astrolab astrolab-sheet">
  <h1 class="astrolab-title width: 100%;" text-align="center">Astrolabium</h1>
  <label class="smallTitle flexrow flex-center" style="font-size: 20pt"
    >{{localize
      (lookup (lookup seasons curSeason) "label")
    }}
    {{ curYear }}</label
  >
  <div class="sheet-body backSection marginsides32" style="height: auto">
    <div class="flexcol" style="margin: 10px">
      <div class="resource-content flexrow">
        <div class="resource-content flexrow flex-center flex-between margintop6">
          <label for="season" class="smallTitle flex0" style="font-size: 16pt">{{localize
              "arm5e.sheet.season"
          }}</label>
          <div class="flexrow">
            <img
              class="nav-arrow clickable season-arrow"
              data-action="prevSeason"
              data-change="{{ dateChange }}"
              title="{{localize 'arm5e.astrolab.prevSeason'}}"
              src="systems/arm5e/assets/bLeft.png"
            />
            <select
              name="season"
              {{dateChange}}
              data-type="String"
              class="change-season flex0 seasons"
              style="font-size: 14pt"
            >
              {{selectOptions seasons selected=season localize=true labelAttr="label"}}
            </select>
            <img
              class="nav-arrow clickable season-arrow"
              data-action="nextSeason"
              data-change="{{ dateChange }}"
              src="systems/arm5e/assets/bRight.png"
              title="{{localize 'arm5e.astrolab.nextSeason'}}"
            />
          </div>
        </div>
        <div class="resource-content flexrow flex-center flex-between margintop6">
          <label for="year" class="smallTitle" style="font-size: 16pt">{{localize
              "arm5e.sheet.year"
          }}</label>
          <input
            type="number"
            name="year"
            {{dateChange}}
            value="{{ year }}"
            data-dtype="Number"
            class="astrolab change-year select-on-focus"
            style="font-size: 18pt"
          />
        </div>
      </div>
      <!-- <div style="margin:10px">
        <label for="date" class="smallTitle" style="font-size:16pt">{{!--localize "arm5e.sheet.date"--}}</label>
        <input type="date" name="date" value="{{date}}" data-dtype="Number" class="astrolab  select-on-focus" style="
        font-size: 18pt;" />
      </div> -->
      <div class="flexrow">
        <div class="flex0">
          <a class="group-schedule flex0" data-action="displaySchedule" style="width: 36px"
            ><i class="ars-icon-Tool_AstrolabBig"></i
          ></a>
        </div>
        <div class="flexrow" style="margin: 10px">
          {{#if (eq dateChange "disabled")}}
          <div
            class="show-calendar"
            data-action="showCalendar"
            style="height: 48px; width: 48px; max-width: 48px"
          >
            <i class="fas fa-calendar simple-calendar-icon"></i>
          </div>
          {{else}}
          <button class="astrolab button set-date" data-action="setDate" style="font-size: 16pt">
            {{localize "arm5e.astrolab.setWorldDate"}}
          </button>
          {{/if}}
          <button class="astrolab button rest-all" data-action="restAll" style="font-size: 16pt">
            {{localize "arm5e.astrolab.restAll"}}
          </button>
        </div>
      </div>
    </div>
    <div>
      <label>{{localize "arm5e.astrolab.trackResources"}}</label>
      <input
        class="trackRes"
        type="checkbox"
        name="trackRes"
        data-dtype="Boolean"
        {{checked
        trackRes}}
      />
    </div>
  </div>
</section>
