<div class="{{ cssClass }} sanatorium sanatorium-sheet" autocomplete="off">
  <div class="flexrow flex-between marginsides32">
    {{>"systems/arm5e/templates/generic/parts/simpleFieldBacksection.hbs" label="arm5e.sheet.stamina" name="sta"
    attributes="readonly" value=patient.system.characteristics.sta.value type="number" dtype="Number" classes="wide"}}
    {{>"systems/arm5e/templates/generic/parts/simpleFieldBacksection.hbs" label="arm5e.sanatorium.recoveryBonus"
    name="recoveryBonus" attributes="readonly" value=modifiers.activeEffect type="number" dtype="Number" classes="wide"}}
    {{>"systems/arm5e/templates/generic/parts/simpleFieldBacksection.hbs" label="arm5e.sanatorium.mundaneHelp" 
        name="modifiers.mundaneHelp" attributes="" value=modifiers.mundaneHelp type="number" dtype="Number" classes="wide select-on-focus change-mundane-help"}}
    {{>"systems/arm5e/templates/generic/parts/simpleFieldBacksection.hbs" label="arm5e.sanatorium.magicalHelp" 
        name="modifiers.magicalHelp" attributes="" value=modifiers.magicalHelp type="number" dtype="Number" classes="wide select-on-focus change-magical-help"}}
    {{>"systems/arm5e/templates/generic/parts/simpleFieldBacksection.hbs" label="arm5e.sanatorium.labHealth" 
        name="modifiers.labHealth" attributes="readonly" value=modifiers.labHealth type="number" dtype="Number" classes="wide"}}
  </div>
  <div class="marginsides32 marginbot6 margintop6">
    {{> "systems/arm5e/templates/generic/metalic-bar.html"  }}
  </div>
  <div class="sheet-body backSection marginsides32">
    {{!-- tyle="min-height: 367px"> --}}
    <div class="flexcol" style="margin: 10px">
      <div class="resource-content flexrow flex-between">
        <div class="resource-content flexrow flex-center flex-between margintop6">
          <label
            for="availableDays"
            class="smallTitle"
            style="font-size: 14pt"
            >{{localize "arm5e.sanatorium.daysAvailbable"}}</label
          >

          <input
            type="number"
            name="availableDays"
            {{dateChange}}
            value="{{ availableDays }}"
            data-dtype="Number"
            class="sanatorium change-available-days select-on-focus"
            style="font-size: 14pt"
          />
        </div>
        <div class="resource-content flexrow flex-center flex-between margintop6">
          <label
            class="smallTitle"
            style="font-size: 16pt"
            >{{localize "arm5e.sheet.season"}}</label
          >
          <input
            type="text"
            readonly
            value="{{ curSeasonLabel }}"
            data-dtype="String"
            class="sanatorium change-season"
            style="font-size: 14pt"
          />
        </div>
        <div class="resource-content flexrow flex-center flex-between margintop6">
          <label
            for="curYear"
            class="smallTitle"
            style="font-size: 16pt"
            >{{localize "arm5e.sheet.year"}}</label
          >
          <input
            type="number"
            name="curYear"
            readonly
            value="{{ curYear }}"
            data-dtype="Number"
            class="sanatorium change-year select-on-focus"
            style="font-size: 18pt"
          />
        </div>
      </div>
      <div class="flexrow">
        <div class="flexcol" style="padding-top: 16px; padding-bottom: 12px; max-height: 300px">
          {{#each wounds }}
          <div class="flexrow">
            {{#each this}}
            <img
              class="{{ this.style }}"
              src="{{ this.img }}"
              title="{{ this.name }} +{{ this.bonus }}"
              style="max-height: 48px; max-width: 48px; margin: 3px"
            />
            {{#if this.locked}}
            <a
              class=""
              title="Locked"
              style="position: relative; right: 14px; top: -14px; max-width: 0px"
            >
              <i class="ars-Icon_Locked_Small"></i>
            </a>
            {{/if}}
            {{/each}}
          </div>
          {{/each}}
        </div>
        <div class="margintop18" style="min-height: 263px">
          <label class="smallTitle">{{localize "arm5e.sanatorium.log"}}</label>
          {{> "systems/arm5e/templates/generic/ars-editor.hbs"
            content=log
            target="log"
            button=false
            editable=false
          }}
        </div>
      </div>
    </div>
    <div class="flexrow">
      <div class="flex-center marginsides10" style="padding-top: 16px">
        <label>{{ daysLeftLabel }}</label>
        <div class="progressbar">
          <div class="progressbar-inner" {{{progressbarStyle}}}></div>
        </div>
      </div>
    </div>
  </div>
  <div class="flexrow marginsides32">
    <button
      class="sanatorium button recovery-roll"
      data-action="recoveryRoll"
      style="font-size: 16pt"
      {{canRoll}}
    >
      {{localize "arm5e.sanatorium.button.recovery"}}
    </button>
    <button
      class="sanatorium button diary-entry"
      data-action="createDiaryEntry"
      style="font-size: 16pt"
      {{diary}}
    >
      {{localize "arm5e.sanatorium.button.endSeason"}}
    </button>
  </div>
</div>
