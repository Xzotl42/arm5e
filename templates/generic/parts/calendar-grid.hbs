<div class="flexrow" style="margin: 10px">
  <div class="flex-center">
    <label for="season" class="smallTitle" style="font-size: 14pt; max-width: 50px"></label>
  </div>
  {{#each config.seasons as |season key|}}
  <div class="flex-center">
    <label for="season" class="smallTitle" style="font-size: 14pt">{{localize season.label}}</label>
  </div>
  {{/each}}
</div>
<div>
  {{> "systems/arm5e/templates/generic/metalic-bar.html"  }}
</div>
<div class="years flexcol" style="overflow-y: auto; max-height: 400px">
  {{#each selectedDates }}
  <div class="backSection calendar-year flex-center flex-between flexrow">
    <div class="flexrow">
      <label for="year" class="smallTitle" style="font-size: 16pt; max-width: 50px">{{
        this.year
      }}</label>
      {{#each this.seasons }}
      <div class="calendar-season {{ this.style }} flexrow">
        <div class="flexrow">
          {{#each this.others}}
          <div class="vignette" data-id="{{ this.id }}">
            <img src="{{ this.img }}" title="{{ this.name }}" {{{this.style}}} />
          </div>
          {{/each}}

          {{#if this.edition}}
          {{#if (eq ../../kind "schedule")}}
          <a
            class="flex0 item-create"
            data-type="diaryEntry"
            data-year="{{../this.year}}"
            data-season="{{@key}}"
            title="Create activity"
            style="padding: 5px"
            ><i class="fa fa-plus fa-xl"></i
          ></a>
          {{else}}
          <input
            type="checkbox"
            name=""
            {{checked
            this.selected}}
            class="selectedSeason"
            data-year="{{../this.year}}"
            data-season="{{@key}}"
            data-selected="{{ this.selected }}"
          />
          {{/if}}
          {{else}}
          <div style="max-width: 25px; max-height: 25px; height: 25px; width: 25px"></div>
          {{/if}}
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/each}}
</div>
