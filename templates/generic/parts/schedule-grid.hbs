<div class="flexrow" style="margin: 10px">
  {{#each config.seasons as |season key|}}
  <div class="flex-center">
    <label for="season" class="smallTitle" style="font-size: 14pt">{{localize season.label}}</label>
  </div>
  {{/each}}
</div>
<div>
  {{> "systems/arm5e/templates/generic/metalic-bar.html" }}
</div>
<div class="{{ type }}-years flexcol">
  {{#each selectedDates }}
  <div class="backSection calendar-year flex-center flex-between flexrow">
    <label for="year" class="smallTitle" style="font-size: 16pt; flex: 0 0 50px">{{
      this.year
    }}</label>
    <div class="flexrow" style="flex: 1">
      {{#each this.seasons }}
      <div
        class="calendar-season {{ this.style }} flexrow item-create"
        data-action="createItem"
        data-type="diaryEntry"
        data-year="{{../this.year}}"
        data-season="{{@key}}"
        title="Create activity"
      >
        <div class="flexrow">
          {{#each this.others}}
          <div class="vignette" data-action="openItem" data-id="{{ this.id }}">
            <img src="{{ this.img }}" title="{{ this.name }}" {{{this.style}}} />
          </div>
          {{/each}}
          <div style="max-width: 25px; max-height: 25px; height: 25px; width: 25px"></div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/each}}
</div>
