<div class="tab {{ tab.cssClass }} arts" data-group="primary" data-tab="arts">
  <div class="flexcol">
    {{> (systemPath "templates/generic/parts/ars-tab-navigation.hbs") tabs=subtabs}}
    <div class="marginsides32">
      {{> (systemPath "templates/generic/metalic-bar.html") }}
    </div>
    <section class="arts-body">
      <div
        class="tab{{#if subtabs.[arts-subtab].active}} active{{/if}} item flexcol marginsides32"
        data-group="arts-secondary"
        data-tab="arts-subtab"
      >
        {{> (systemPath "templates/actor/parts/actor-arts.html") }}
      </div>
      <div
        class="tab{{#if subtabs.[casting-total].active}} active{{/if}} item flexcol marginsides32"
        data-group="arts-secondary"
        data-tab="casting-total"
      >
        {{> (systemPath "templates/actor/parts/actor-castingTotals.html") }}
      </div>
    </section>
  </div>
</div>
