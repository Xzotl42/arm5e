<div class="flex-group-left backSection padding12">
  <div class="flexrow" style="max-height: 32px">
    <div style="margin-top: 6px">
      <span class="section-title"
        >{{localize "arm5e.sheet.fatigue.label"}} ({{ system.fatigueTotal }})</span
      >
    </div>
    <div style="margin-top: 12px; max-width: 40px">
      <a
        class="item-control removeFatigue"
        data-action="removeFatigue"
        title="{{localize 'arm5e.sheet.fatigue.recover'}}"
        ><i class="fas fa-minus fa-lg"></i
      ></a>
      <a
        class="item-control addFatigue"
        data-action="addFatigue"
        title="{{localize 'arm5e.sheet.fatigue.add'}}"
      >
        <i class="fas fa-plus fa-lg"></i
      ></a>
    </div>
    <div>
      <img
        class="fatigueRoll rollable tinyimg"
        data-action="roll"
        data-roll="option"
        data-physicalcondition="true"
        data-title="{{localize 'arm5e.sheet.fatigue.roll'}}"
        data-name="{{localize 'arm5e.sheet.fatigue.roll'}}"
        data-mode="1"
        data-difficulty="6"
        data-option1="{{ system.characteristics.sta.value }}"
        data-fatigue-on-fail="1"
        data-txtoption1="{{ localize config.character.characteristics.sta.label }}"
        data-txtoption2="{{ localize 'arm5e.activeEffect.subtypes.fatigueRolls' }}"
        data-option2="{{ system.bonuses.rolls.fatigue }}"
        src="systems/arm5e/assets/icons/fatigue.svg"
        title="{{localize 'arm5e.sheet.fatigue.roll' }}"
      />
    </div>

    <button class="arm5e rest" data-action="actorRest" style="max-height: 32px">
      {{localize "arm5e.sheet.action.rest"}} {{ system.fatigueTime }} {{ system.fatigueRestUnit }}
    </button>
  </div>

  <ol>
    <div class="flexrow flex-between marginbot6"></div>
    {{#each system.fatigue as |fatigue key|}}
    <span class="grid grid-4col">
      {{#with (lookup @root.config.character.fatigueLevels key)}}
      <label for="config.character.fatigueLevels.{{ key }}.label">{{localize label}}</label>
      {{/with}}
      <li class="flexrow" data-attribute="{{ key }}">
        {{#each fatigue.levels}}
        <!-- <input type="checkbox" name="system.fatigue.{{key}}.level.value" {{checked fatigue.level.value}} /> -->
        <input
          type="checkbox"
          disabled="disabled"
          name=""
          {{checked
          this.state
          }}
          class="{{ this.lt }}"
        />
        {{/each}}
      </li>
      <input
        type="text"
        name="system.fatigue.{{ key }}.number"
        value="{{numberFormat fatigue.number decimals=0 sign=true}}"
        data-dtype="Number"
        readonly
      />
      {{#with (lookup @root.config.character.fatigueLevels key)}}
      <input
        type="text"
        value="{{ timeLabel }} {{localize timeUnits}}"
        data-dtype="String"
        readonly
      />
      {{/with}}
    </span>
    {{/each}}
  </ol>
</div>
