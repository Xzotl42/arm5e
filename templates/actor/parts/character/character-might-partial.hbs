{{!--
  Might pool details for entity/creature character subtypes.
  Shown in the description tab when features.might is true.
--}}
<div class="flex-group-left padding12 backSection margintop18">
  <label class="smallTitle">{{localize "arm5e.sheet.might"}}</label>
  <div class="grid grid-2col margintop6">
    <div class="flexcol">
      <label class="bold">{{localize "arm5e.sheet.mightForm"}}</label>
      <select name="system.might.form" data-type="String">
        {{selectOptions config.magic.forms selected=system.might.form labelAttr="label"}}
      </select>
    </div>
    <div class="flexcol">
      <label class="bold">{{localize "arm5e.sheet.realm"}}</label>
      <select class="change-realm" name="" data-type="String" data-realm="{{ system.realm }}">
        {{selectOptions config.realmsExt selected=system.realm labelAttr="label" localize=true}}
      </select>
    </div>
  </div>
  <div class="flexrow margintop6">
    <div class="resource flex-group-center backSection">
      <label class="smallTitle">{{localize "arm5e.sheet.mightPool"}}</label>
      <div class="resource-content flexrow flex-center flex-between margintop6">
        <input
          type="number"
          name="system.might.points"
          value="{{ system.might.points }}"
          data-dtype="Number"
          style="width: 48px; text-align: center"
          class="select-on-focus"
        />
        &nbsp;/&nbsp;
        <input
          type="number"
          name="system.might.value"
          value="{{ system.might.value }}"
          data-dtype="Number"
          style="width: 48px; text-align: center"
          class="select-on-focus"
        />
      </div>
    </div>
  </div>
</div>
