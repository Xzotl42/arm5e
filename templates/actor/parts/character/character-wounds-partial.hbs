<div class="flex-group-left backSection padding12">
  <div class="flexrow">
    <div class="flexcol">
      <span class="section-title"
        >{{localize "arm5e.sheet.wounds"}} ({{ system.penalties.wounds.total }})</span
      >
      <label class="smallTitle clickable view-med-history" data-action="viewMedicalHistory"
        ><i>{{localize "arm5e.sanatorium.viewMedicalHistory"}}</i></label
      >
    </div>
    <div class="soak-icon" title="">
      <a
        class="damage-roll rollable"
        data-action="roll"
        data-roll="damage"
        title="{{localize 'Damage roll'}}"
        style="text-align: right; font-size: 16pt"
      >
        <i class="ars-Icon_Soak_Big"></i
      ></a>
    </div>
    {{#unless isDead}}
    <div>
      <a
        class="recovery-start clickable"
        data-action="recoveryStart"
        title="{{localize 'arm5e.sanatorium.woundsRecovery'}}"
        style="text-align: right; font-size: 16pt"
      >
        <i class="ars-Icon_Sanatorium2"></i>
      </a>
    </div>
    {{/unless}}
  </div>
  <ol>
    <li class="flexrow flex-group-left">
      <div style="min-width: 180px"></div>
      <div class="wound-label">{{localize config.character.wounds.labels.number}}</div>
      <div class="wound-label">{{localize config.character.wounds.labels.penalty}}</div>
    </li>
    {{#each health as |level key|}}
    <li class="flexrow flex-group-left" data-attribute="{{ key }}">
      <div class="flexrow flex-between">
        <div style="position: relative; right: 25px; max-width: 0px; top: 6px">
          <a
            class="item-control add-wound"
            data-action="addWound"
            title="Add wound"
            data-type="{{ key }}"
          >
            <i class="fas fa-plus fa-lg"></i
          ></a>
        </div>
        {{#with (lookup @root.config.character.wounds key)}}
        <label
          for="{{ label }}"
          class="flex05"
          title="{{ wounds.range }}"
          style="display: flex; align-items: center"
          >{{localize label}}</label
        >
        {{/with}}
        <div class="flexrow" style="width: 230px">
          {{#each level.wounds}}
          <img
            class="item wound-edit flexrow vignette"
            data-action="woundEdit"
            data-id="{{ this._id }}"
            src="{{ this.img }}"
            title="{{ this.system.title }}"
            {{{this.system.ui.style}}}
          />
          {{/each }}
        </div>
        <div class="flexrow flex-group-right" style="min-width: 150px">
          <div>
            <span class="wound-label">{{ level.range }} </span>
          </div>
          <div class="wound-field">
            <input
              type="text"
              name=""
              value="{{ level.wounds.length }}"
              data-dtype="Number"
              class="select-on-focus"
              style="text-align: center"
              readonly
            />
          </div>
          <div class="wound-field">
            <input
              type="text"
              value="{{lookup ../system.penalties.wounds key}}"
              data-dtype="Number"
              readonly
              style="text-align: center"
            />
          </div>
        </div>
      </div>
    </li>
    {{/each}}
  </ol>
</div>
