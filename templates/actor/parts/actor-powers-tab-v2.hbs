<div class="tab {{ tab.cssClass }} powers marginsides32" data-group="primary" data-tab="powers">
  <div class="flexrow backSection margintop18">
    <ol class="items-list">
      <li class="item flexrow item-header">
        <div class="item-image"></div>
        <div class="item-name">{{localize "arm5e.sheet.powers"}}</div>
        <div class="item-controls">
          <a
            class="item-control item-create"
            data-action="itemCreate"
            title="{{localize 'arm5e.hints.create' item=(localize 'arm5e.sheet.power')}}"
            data-type="power"
            ><i class="fas fa-plus"></i
          ></a>
        </div>
      </li>
      {{> "systems/arm5e/templates/generic/metalic-bar.html" }}
      {{#each system.powers as |item id|}}
      <li class="item item-value flexrow" data-name="{{ item.name }}" data-item-id="{{ item._id }}">
        <div class="item-image item-control item-edit" data-action="itemEdit">
          <img src="{{ item.img }}" title="{{ item.name }}" />
        </div>
        <div class="flexrow flex-center">
          <span
            class="flexrow item-title width4 clickable power-use"
            data-action="powerUse"
            name="item.name"
            data-id="{{ item._id }}"
            data-name="{{ item.name }}"
            data-roll="power"
            data-cost="{{ item.system.cost }}"
          >
            {{ item.name }}
          </span>
          <span class="bold" name="item.name">
            {{localize "arm5e.sheet.initiativeShort"}}: {{ item.system.init }}
          </span>
          <span class="bold" name="item.name">
            {{#with (lookup @root.config.magic.forms item.system.form)~}}{{label~}}{{/with}}
          </span>
          <span class="bold" name="item.name">
            {{ item.system.cost }} {{localize "arm5e.sheet.points"}}
          </span>
        </div>
        <div class="item-controls">
          <a
            class="item-control item-edit"
            data-action="itemEdit"
            title="{{localize 'arm5e.hints.edit' item=(localize 'arm5e.sheet.power')}}"
            ><i class="ars-Icon_Edit"></i
          ></a>
          <a
            class="item-control item-delete"
            data-action="itemDelete"
            title="{{localize 'arm5e.hints.delete' item=(localize 'arm5e.sheet.power')}}"
            ><i class="ars-Icon_Delete_Hand_Gesture"></i
          ></a>
        </div>
      </li>
      {{/each}}
    </ol>
  </div>
</div>
