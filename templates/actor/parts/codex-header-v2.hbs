<div>
  <div class="header-background">
    <img src="systems/arm5e/assets/codex/header150.webp" />
  </div>

  <h1 class="codex-title" style="width: 100%; text-align: center">Codex Hermeticum</h1>
  <br />
  <header class="sheet-header-codex marginsides32">
    <div>{{localize "arm5e.sheet.filters"}}</div>
    <div class="header-fields">
      <div class="flexrow flex-between">
        <span class="codexname flexrow" style="padding-top: 4px">
          <div class="resource flexrow">
            <label for="system.technique.value">{{localize "arm5e.sheet.withCompendium"}}</label>
            <input type="checkbox" name="system.withCompendia" {{checked system.withCompendia}} />
          </div>
        </span>
        <span class="codexname flexrow" style="padding-top: 4px; flex-wrap: nowrap">
          <label
            for="techniqueFilter"
            style="padding-right: 10px; text-align: right"
            >{{localize "arm5e.sheet.technique"}}</label
          >
          <select
            name="techniqueFilter"
            class="technique-filter textValue"
            data-type="String"
            data-list="filter"
            data-category="hermetic"
            style="flex: 0 0 80px; font-size: 11pt"
          >
            {{selectOptions config.magic.techniques selected=ui.filters.hermetic.filter.techniqueFilter labelAttr="label" blank="" }}
          </select>
        </span>
        <span class="codexname flexrow" style="padding-top: 4px; flex-wrap: nowrap">
          <label
            for="formFilter"
            style="padding-right: 10px; text-align: right"
            >{{localize "arm5e.sheet.form"}}</label
          >
          <select
            name="formFilter"
            data-type="String"
            class="form-filter textValue"
            data-list="filter"
            data-category="hermetic"
            style="flex: 0 0; font-size: 11pt"
          >
            {{selectOptions config.magic.forms selected=ui.filters.hermetic.filter.formFilter labelAttr="label" blank="" }}
          </select>
        </span>
        <span class="codexname flexrow" style="padding-top: 4px; flex-wrap: nowrap">
          <label
            for="levelFilter"
            style="padding-left: 24px"
            >{{localize "arm5e.sheet.level"}}</label
          >
          <select
            name="levelOperator"
            data-type="Number"
            data-list="filter"
            data-category="hermetic"
            style="flex: 0 0; font-family: bookAntiqua"
            class="levelOperator-filter numValue"
          >
            {{selectOptions config.genericOptions.filterOperator selected=ui.filters.hermetic.filter.levelOperator nameAttr="key" valueAttr="key" labelAttr="label"}}
          </select>
          <input
            type="number"
            name="levelFilter"
            data-list="filter"
            data-category="hermetic"
            value="{{ ui.filters.hermetic.filter.levelFilter }}"
            data-dtype="Number"
            class="level-filter"
          />
        </span>
      </div>
    </div>
  </header>
</div>
