<div class="sheet-header-part">
  <div class="header-background">
    <img src="systems/arm5e/assets/item/{{ flavor }}_header.png" />
  </div>
  <header class="sheet-header marginItemPart">
    <img
      class="item-img"
      src="{{ item.img }}"
      data-action="editImage"
      data-edit="img"
      title="{{ item.name }}"
    />
    <div class="header-fields">
      <h1 class="bigname">
        <input name="name" type="text" value="{{ item.name }}" placeholder="name" />
      </h1>
      <div class="flexcol">
        <div class="resource flexrow">
          <label>{{localize 'Art key'}}</label>
          <input type="text" name="system.key" value="{{ system.key }}" data-dtype="String" />
        </div>
        <div class="resource flexrow">
          <label class="checkbox-label">{{localize 'Accelerated'}}</label>
          <input type="checkbox" name="system.accelerated" {{checked system.accelerated}} />
        </div>
        {{#if isOwned}}
        <div class="flexrow" style="padding-top: 5px">
          <label style="max-width: 65px"
            >{{localize 'arm5e.sheet.score'

            }}<input
              type="number"
              name="system.finalScore"
              value="{{ system.finalScore }}"
              data-dtype="Number"
              readonly
          /></label>
          <div
            class="ressource flex0"
            style="padding-top: 8px; padding-left: 8px; padding-right: 8px"
          >
            <a
              class="item-control increase-score"
              data-action="increaseScore"
              title="Increase score"
              ><i class="fas fa-plus"></i
            ></a>
            <a
              class="item-control decrease-score"
              data-action="decreaseScore"
              title="Decrease score"
              ><i class="fas fa-minus"></i
            ></a>
          </div>
          <div class="flexrow" style="max-width: 65px">
            <label
              >{{localize 'arm5e.sheet.experienceShort'

              }}<input
                type="number"
                name="system.xp"
                value="{{ system.xp }}"
                class="select-on-focus"
                data-dtype="Number"
            /></label>
          </div>
        </div>
        {{/if}}
      </div>
    </div>
  </header>
  <div class="marginItemPart">{{> "systems/arm5e/templates/generic/metalic-bar.html" }}</div>
</div>
