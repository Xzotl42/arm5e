<div class="sheet-header-part">
  <div class="header-background">
    <img src="{{systemPath}}assets/item/{{ flavor }}_header.png" />
  </div>
  <header class="sheet-header marginItemPart">
    <img
      class="item-img"
      src="{{ item.img }}"
      data-action="editImage"
      data-edit="img"
      data-tooltip="<img
      class='img-tooltip'
      src='{{ item.img }}'/>"
      data-tooltip-direction="CENTER"
      title="{{ item.name }}"
    />
    <div class="header-fields flexcol">
      <h1 class="bigname">
        <input name="name" type="text" value="{{ item.name }}" placeholder="Name" />
      </h1>
      <div class="resource flexrow">
        <div class="resource flexcol">
          <label>{{localize 'arm5e.sheet.cost'}}</label>
          <input
            name="system.cost"
            type="number"
            value="{{ system.cost }}"
            placeholder="0"
            class="select-on-focus"
          />
        </div>
        <div class="resource flexcol">
          <label>{{localize 'arm5e.sheet.initiative'}}</label>
          <input
            name="system.init"
            type="number"
            value="{{ system.init }}"
            placeholder="0"
            class="select-on-focus"
          />
        </div>
        <div class="resource flexcol">
          <label>{{localize 'arm5e.sheet.form'}}</label>
          <select name="system.form" data-type="String">
            {{selectOptions selection.forms selected=system.form labelAttr='label'}}
          </select>
        </div>
      </div>
      {{#unless ui.ownerHasMight}}
      <div class="resource flexrow">
        <div class="resource flexcol">
          <label>{{localize 'arm5e.realm.label'}}</label>
          <select name="system.realm" data-type="String">
            {{selectOptions config.realmsExt selected=system.realm labelAttr='label' localize=true}}
          </select>
        </div>
        <div class="resource flexcol">
          <label>{{localize 'arm5e.sheet.penetration'}}</label>
          <input
            name="system.penetration"
            type="number"
            value="{{ system.penetration }}"
            placeholder="0"
            class="select-on-focus"
          />
        </div>
      </div>
      {{/unless}}
    </div>
    {{#if editable}}
    <a data-action="itemDeleteConfirm" title="{{localize 'arm5e.hints.delete' item=item.name}}"
      ><i class="ars-Icon_Delete_Hand_Gesture item-delete-large"></i
    ></a>
    {{/if}}
  </header>
  <div class="marginItemPart">{{> (systemPath "templates/generic/metalic-bar.html") }}</div>
</div>
