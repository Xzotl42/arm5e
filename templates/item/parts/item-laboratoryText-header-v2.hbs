<div class="sheet-header-part">
  <div class="header-background">
    <img src="systems/arm5e/assets/item/{{ flavor }}_header.png" />
  </div>
  <header class="sheet-header marginItemPart">
    <img
      class="item-img"
      src="{{ item.img }}"
      data-action="editImage"
      data-edit="img"
      data-tooltip="<img
      class='img-tooltip'
      src='{{ item.img }}'/>"
      data-tooltip-direction="CENTER"
      title="{{ item.name }}"
    />
    <div class="header-fields flexcol">
      <div class="flexrow" style="align-items: end; gap: 8px">
        <div class="resource">
          <label>{{localize "arm5e.sheet.type"}}</label>
          <select class="width2" name="system.type" data-type="String" {{noSelect}}>
            {{selectOptions config.lab.labTextType selected=system.type localize=true}}
          </select>
        </div>
        <div class="resource flexcol flex-center">
          <label>{{localize "Draft"}}</label>
          <input
            type="checkbox"
            name="system.draft"
            data-dtype="Boolean"
            {{checked
            system.draft}}
            {{noSelect}}
          />
        </div>
        {{> "systems/arm5e/templates/item/parts/cost.hbs" classes="fit"}}
      </div>

      {{#if locked}}<i class="ars-Icon_Locked"></i>{{/if}}

      <h1 class="bigname">
        <div class="flexrow">
          <input name="name" type="text" value="{{ item.name }}" placeholder="Name" {{noEdit}} />
          {{#if canBeRead}}
          <div class="flex0 padding6">
            <a
              data-action="studyLabtext"
              title="{{localize 'arm5e.hints.read' item=(localize 'arm5e.sheet.book')}}"
              ><i class="ars-Icon_Readspell"></i
            ></a>
          </div>
          {{/if}}
          {{#if editable}}
          <div class="flex0 padding6">
            <a
              data-action="itemDeleteConfirm"
              title="{{localize 'arm5e.hints.delete' item=item.name}}"
              ><i class="ars-Icon_Delete_Hand_Gesture item-delete-large"></i
            ></a>
          </div>
          {{/if}}
        </div>
      </h1>

      <div class="padding4 flexrow">
        <div class="resource">
          <label>{{localize "arm5e.sheet.authorship.author"}}</label>
          <input
            type="text"
            name="system.author"
            value="{{ system.author }}"
            data-dtype="String"
            {{noEdit}}
          />
        </div>
        <div class="resource">
          <label>{{localize "arm5e.sheet.authorship.language"}}</label>
          <input
            type="text"
            name="system.language"
            value="{{ system.language }}"
            data-dtype="String"
            {{noEdit}}
          />
        </div>
        <div class="resource">
          <label>{{localize "arm5e.sheet.season"}}</label>
          <select name="system.season" data-dtype="String" {{noSelect}}>
            {{selectOptions config.seasons selected=system.season labelAttr="label" localize=true}}
          </select>
        </div>
        <div class="resource">
          <label>{{localize "arm5e.sheet.year"}}</label>
          <input
            type="number"
            name="system.year"
            value="{{ system.year }}"
            data-dtype="Number"
            class="select-on-focus"
            style="width: 60px"
            {{noEdit}}
          />
        </div>
      </div>

      {{#unless (eq system.type "raw")}}
      <div class="padding2">
        <label>{{ system.localizedDesc }}</label>
      </div>
      {{/unless}}
    </div>
  </header>
  <div class="marginItemPart">{{> "systems/arm5e/templates/generic/metalic-bar.html"}}</div>
</div>
