<div class="sheet-header-part">
  <div class="header-background">
    <img src="systems/arm5e/assets/item/{{ flavor }}_header.png" />
  </div>
  <header class="sheet-header marginItemPart">
    <img
      class="item-img"
      src="{{ item.img }}"
      data-action="editImage"
      data-edit="img"
      data-tooltip="<img
      class='img-tooltip'
      src='{{ item.img }}'/>"
      data-tooltip-direction="CENTER"
      title="{{ item.name }}"
    />
    <div class="header-fields">
      <h1 class="bigname">
        <div class="flexrow">
          <input
            name="name"
            type="text"
            value="{{ item.name }}"
            title="{{ item.name }}"
            placeholder="name"
            class="item-name"
          />
        </div>
      </h1>
      {{#unless altArt}}
      <div class="resource">
        <label>{{localize 'arm5e.sheet.speciality'}}</label>
        <input
          type="text"
          name="system.speciality"
          value="{{ system.speciality }}"
          data-dtype="String"
        />
      </div>
      {{/unless}}
      {{#if isOwned}}
      <div class="flexrow" style="padding-top: 5px">
        <label style="max-width: 65px"
          >{{localize 'arm5e.sheet.score'

          }}<input
            type="number"
            name="system.finalScore"
            value="{{ system.finalScore }}"
            data-dtype="Number"
            readonly
        /></label>
        <div
          class="ressource flex0"
          style="padding-top: 8px; padding-left: 8px; padding-right: 8px"
        >
          <a class="item-control increase-score" data-action="increaseScore" title="Increase score"
            ><i class="fas fa-plus"></i
          ></a>
          <a class="item-control decrease-score" data-action="decreaseScore" title="Decrease score"
            ><i class="fas fa-minus"></i
          ></a>
        </div>
        <div class="flexrow" style="max-width: 65px">
          <label
            >{{localize 'arm5e.sheet.experienceShort'
            }}<input
              type="number"
              name="system.xp"
              value="{{ system.xp }}"
              class="select-on-focus"
              data-dtype="Number"
          /></label>
        </div>
      </div>
      {{/if}}
      <div class="resource flexrow">
        {{#if canBeAccelerated}}
        <div class="resource flexrow">
          <label class="checkbox-label">{{localize 'Accelerated'}}</label>
          <input
            type="checkbox"
            name="system.accelerated"
            data-dtype="Boolean"
            {{checked
            system.accelerated}}
          />
        </div>
        {{/if}}
        {{#unless altArt}}
        <div class="flexcol">
          <label>{{localize 'arm5e.sheet.defaultCharacteristicForAbility'}}</label>
          <select name="system.defaultChaAb" data-type="String">
            {{selectOptions config.character.characteristics selected=system.defaultChaAb localize=true labelAttr='label'}}
          </select>
        </div>
        {{/unless}}
        {{#if (eq system.category 'supernaturalCat')}}
        <div class="flexcol" style="padding-left: 5px">
          <label>{{localize 'arm5e.realm.label'}}</label>
          <select name="system.realm" data-type="String">
            {{selectOptions config.realmsExt selected=system.realm labelAttr='label' localize=true}}
          </select>
        </div>
        {{/if}}
        {{#if isOwned}}
        <div class="flexrow">
          <a
            class="item-control item-delete-confirm"
            data-action="itemDeleteConfirm"
            title="{{localize 'arm5e.hints.delete' item=item.name}}"
            ><i class="ars-Icon_Delete_Hand_Gesture"></i
          ></a>
        </div>
        {{/if}}
      </div>
    </div>
  </header>
  <div class="marginItemPart">{{> "systems/arm5e/templates/generic/metalic-bar.html" }}</div>
</div>
