<div class="sheet-header-part">
  <div class="header-background">
    <img src="{{systemPath}}assets/item/{{ flavor }}_header.png" />
  </div>
  <header class="sheet-header marginItemPart">
    <div class="flexcol max-w-fit">
      <img
        class="item-img"
        src="{{ item.img }}"
        data-action="editImage"
        data-edit="img"
        data-tooltip="<img class='img-tooltip' src='{{ item.img }}'/>"
        data-tooltip-direction="CENTER"
        title="{{ item.name }}"
      />
    </div>
    <div class="header-fields flexcol">
      <h1 class="bigname">
        <div class="flexrow">
          <input
            name="name"
            type="text"
            value="{{ item.name }}"
            placeholder="{{localize 'arm5e.generic.name'}}"
            {{noEdit}}
          />
          {{#if isOwned}}
          <div class="flex0 padding6">
            <a
              data-action="itemDeleteConfirm"
              title="{{localize 'arm5e.hints.delete' item=(localize 'arm5e.sheet.diary')}}"
              ><i class="ars-Icon_Delete_Hand_Gesture"></i
            ></a>
          </div>
          {{/if}}
        </div>
      </h1>
      {{!-- Start date row --}}
      <div class="flexrow">
        <div class="resource flex0">
          <label>{{localize "arm5e.generic.begins"}}: </label>
        </div>
        <div class="resource">
          <label>{{localize "arm5e.sheet.year"}}</label>
          <input
            type="number"
            name="system.dates.0.year"
            value="{{ firstSeason.year }}"
            class="select-on-focus change-year"
            data-dtype="Number"
            {{ui.editDate}}
          />
        </div>
        <div class="resource">
          <label>{{localize "arm5e.sheet.season"}}</label>
          <select
            name="system.dates.0.season"
            class="change-season"
            data-dtype="String"
            {{ui.editDate}}
          >
            {{selectOptions config.seasons selected=firstSeason.season labelAttr="label" localize=true}}
          </select>
        </div>
      </div>

      {{!-- End date row (multi-season activities) --}}
      {{#if (gt system.duration 1)}}
      <div class="flexrow">
        <div class="resource flex0">
          <label>{{localize "arm5e.generic.ends"}}: </label>
        </div>
        <div class="resource">
          <label>{{localize "arm5e.sheet.year"}}</label>
          <input type="number" value="{{ lastSeason.year }}" data-dtype="Number" disabled />
        </div>
        <div class="resource">
          <label>{{localize "arm5e.sheet.season"}}</label>
          <select data-dtype="String" disabled>
            {{selectOptions config.seasons selected=lastSeason.season labelAttr="label" localize=true}}
          </select>
        </div>
      </div>
      {{/if}}

      <div class="flexrow">
        {{!-- Free date text --}}

        <div class="flexrow">
          <div class="resource">
            <label>{{localize "arm5e.sheet.date"}}</label>
            <input
              type="text"
              name="system.dates.0.date"
              value="{{ firstSeason.date }}"
              data-dtype="String"
              {{noEdit}}
            />
          </div>
        </div>

        {{!-- Activity select --}}
        <div class="flexrow">
          <div class="resource flex2">
            <label>{{localize "arm5e.activity.activity"}}</label>
            <select
              class="progress-activity"
              name="system.activity"
              data-dtype="String"
              style="width: 100%"
              {{activityState}}
            >
              {{selectOptions selection.activities selected=system.activity localize=true}}
            </select>
          </div>
        </div>
      </div>
      {{!-- Duration / progress / calendar  --}}
      <div class="flex-group-left flexrow">
        <div class="marginsides10 resource">
          <label>{{localize "arm5e.sheet.duration"}}</label>
          <input
            type="number"
            class="duration select-on-focus slim"
            name="system.duration"
            value="{{ system.duration }}"
            data-dtype="Number"
            {{ui.editDuration}}
          />
        </div>
        {{#if (gt system.duration 1)}}
        <div class="marginsides10 resource">
          <label>{{localize "arm5e.sheet.progress"}}</label>
          <input type="text" class="select-on-focus slim" value="{{ progress }}" readonly />
        </div>
        {{/if}}
        {{#if ui.schedule}}
        <div class="marginsides10 resource">
          <a data-action="selectDates" class="slim">
            <i {{{astrolabIconStyle}}} class="ars-icon-Tool_AstrolabBig"></i>
          </a>
        </div>
        {{/if}}
      </div>
    </div>
  </header>
  <div class="marginItemPart">
    {{> (systemPath "templates/generic/metalic-bar.html")}}
  </div>
</div>
