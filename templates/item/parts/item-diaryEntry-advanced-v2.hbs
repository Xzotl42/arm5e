{{!-- Advanced tab content for diaryEntry V2 sheet --}}
<div
  class="tab {{ tab.cssClass }} marginItemPart advanced"
  data-group="primary"
  data-tab="advanced"
>
  <div class="flexcol">
    {{!-- Source quality row and progress sections (only for progress-based activities) --}}
    {{#if ui.showProgress}}
    <div>
      <div style="position: absolute; right: -2300px">
        <input
          type="hidden"
          name="system.sourceModifier"
          value="{{ system.sourceModifier }}"
          data-dtype="Number"
        />
      </div>
      <div class="resource">
        <label class="">{{localize "arm5e.sheet.sourceQuality"}} : </label>
        {{#if ui.editSource}}
        <input
          type="text"
          name="system.sourceQuality"
          value="{{ system.sourceQuality }}"
          data-dtype="Number"
          {{system.canEdit}}
          style="max-width: 50px"
        />
        {{else}}
        {{#if system.done}}
        <label class=""
          ><b>{{ system.sourceQuality }}</b></label
        >
        {{else}}
        {{#if ui.showBaseQuality}}
        <label class=""> {{localize "arm5e.generic.base"}} ({{ system.sourceQuality }})</label>
        {{else}}
        <label class="">
          : {{localize "arm5e.generic.default"}} ({{ system.sourceDefault }})
        </label>
        {{/if}}
        {{/if}}
        {{/if}}
        {{#if ui.bonusOptions}}
        <label class=""> + </label>
        <select
          class="progress-bonus"
          name="system.optionKey"
          data-dtype="String"
          {{system.disabled}}
        >
          {{selectOptions bonusOptions selected=system.optionKey labelAttr="selectLabel"}}
        </select>
        {{/if}}
        {{#unless (or (eq system.sourceModifier 0) system.cappedGain)}}
        <label class=""> + </label>
        <label class="">
          {{localize "arm5e.sheet.bonus.activeEffects"}} ({{ system.sourceModifier }})</label
        >
        {{/unless}}
        {{#unless system.cappedGain}}
        <label class="">
          = <b>{{ totalQuality }}</b></label
        >
        {{else}}
        <label class="">
          => <b>{{ system.sourceQuality }} *</b></label
        >
        {{/unless}}
      </div>
    </div>
    {{!-- Inner advanced-secondary tab navigation --}}
    {{> (systemPath "templates/generic/parts/ars-tab-navigation.hbs") tabs=subtabs navClass=subtabNavClass navStyle=subtabNavStyle}}

    <section class="diary-body">
      {{!-- {{log "TEACHER TAB" }} --}}
      {{!-- Teacher tab --}}
      <div
        class="tab{{#if subtabs.teacher.active}} active{{/if}} item flexcol marginItemPart"
        data-tab="teacher"
        data-group="advanced-secondary"
      >
        <section
          class="progress-teacher flexrow flex-group-left backSection"
          data-tab="teacher"
          style="height: 200px; margin: 5px"
        >
          <div class="flexcol">
            <label class="">{{localize "arm5e.activity.teacher.name"}}</label>
            <input
              type="text"
              name="system.teacher.name"
              value="{{ system.teacher.name }}"
              data-dtype="String"
              style="max-width: 220px"
              {{system.canEditTeacher}}
              class="select-on-focus"
            />
            {{#if (eq system.activity "teaching")}}
            <div class="flexrow">
              <label class="">{{localize "arm5e.sheet.com"}}</label>
              <input
                type="number"
                name="system.teacher.com"
                value="{{ system.teacher.com }}"
                data-dtype="Number"
                style="max-width: 50px"
                {{system.canEditTeacher}}
                class="select-on-focus"
              />
            </div>
            <div class="flexrow">
              <label class="">{{localize "arm5e.skill.general.teaching"}}</label>
              <input
                type="number"
                name="system.teacher.teaching"
                value="{{ system.teacher.teaching }}"
                data-dtype="Number"
                style="max-width: 50px"
                {{system.canEditTeacher}}
                class="select-on-focus"
              />
            </div>
            <div class="flexrow">
              <label class=""
                >{{localize "arm5e.sheet.speciality"}} ({{ system.teacher.speciality }})</label
              >
              <input
                type="checkbox"
                name="system.teacher.applySpec"
                {{checked
                system.teacher.applySpec}}
                data-dtype="Boolean"
                {{system.disabled}}
              />
            </div>
            {{/if}}
            {{#unless system.teacherLinked}}
            <div class="flexrow">
              <label class="">{{localize "arm5e.sheet.score"}}</label>
              <input
                type="number"
                class="score-teacher"
                name="system.teacher.score"
                value="{{ system.teacher.score }}"
                data-dtype="Number"
                style="max-width: 50px"
                {{system.canEditTeacher}}
                class="select-on-focus"
              />
            </div>
            {{/unless}}
          </div>
          <div class="flexcol" style="text-align: center">
            {{#if (eq system.teacher.id null)}}
            <label style="padding: 15px">{{localize "arm5e.activity.drop.teacher"}}</label>
            {{else}}
            <a data-action="resetTeacher" title="Break link to teacher">
              <i class="fas fa-link" style="font-size: 18pt"></i>
            </a>
            {{/if}}
          </div>
        </section>
      </div>

      {{!-- Abilities tab --}}
      {{!-- {{log "ABILITIES TAB" }} --}}
      <div
        class="tab{{#if subtabs.abilities.active}} active{{/if}} item flexcol marginItemPart progress-abilities"
        data-tab="abilities"
        data-group="advanced-secondary"
      >
        <header class="effect-change effects-header flexrow">
          <div class="type">{{localize "arm5e.skill.category.label"}}</div>
          <div class="key">{{localize "arm5e.sheet.ability"}}</div>
          {{#if ui.showTeacher}}
          <div class="teacher-score">{{localize "arm5e.activity.teacher.score"}}</div>
          {{else}}
          <div class="xpamount">{{localize "arm5e.sheet.experience"}}</div>
          {{/if}}
          <div class="progress-controls">
            {{#unless system.canProgress.abilities}}
            {{localize "arm5e.activity.msg.noAbility"}}
            {{else}}
            <a
              data-action="progressControl"
              data-subaction="add"
              data-type="abilities"
              data-default="{{ system.defaultAbility }}"
              data-secondary="{{ system.isDefaultSecondary }}"
              data-defaultkey="{{ system.defaultAbilityKey }}"
              data-defaultoption="{{ system.defaultAbilityOption }}"
              data-teacherscore="{{ system.teacherScore }}"
            >
              <i class="fas fa-plus"></i>
            </a>
            {{/unless}}
          </div>
        </header>
        <div class="resource">
          <ol class="progresses-list">
            {{#each system.progress.abilities as |ability idx|}}
            <li class="item diary-progress flexrow">
              <select
                name="system.progress.abilities.{{ idx }}.category"
                data-dtype="String"
                data-index="{{ idx }}"
                data-type="abilities"
                {{@root.system.disabled}}
                class="progress-category ability-key flex02"
                style="min-width: 135px"
              >
                {{selectOptions @root.selection.abilityCategories selected=ability.category}}
              </select>
              <select
                name="system.progress.abilities.{{ idx }}.id"
                data-dtype="String"
                data-index="{{ idx }}"
                data-type="abilities"
                class="progress-ability flex02"
                {{@root.system.disabled}}
                style="min-width: 150px"
              >
                {{selectOptions (lookup @root.system.ownedAbilities ability.category) selected=ability.id
                nameAttr="id" valueAttr="id" labelAttr="label"}}
              </select>
              <div class="xp">
                {{#unless ../ui.showTeacher}}
                <input
                  type="number"
                  name="system.progress.abilities.{{ idx }}.xp"
                  value="{{ ability.xp }}"
                  data-dtype="Number"
                  data-index="{{ idx }}"
                  data-type="abilities"
                  {{@root.system.canEdit}}
                  class="progress-xp flex0 select-on-focus"
                  style="width: 50px"
                  min="0"
                  step="1"
                />
                {{else}}
                <input
                  type="number"
                  name="system.progress.abilities.{{ idx }}.teacherScore"
                  value="{{ ability.teacherScore }}"
                  data-dtype="Number"
                  data-index="{{ idx }}"
                  data-type="abilities"
                  readonly
                  class="flex0"
                  style="width: 50px"
                  min="0"
                  step="1"
                />
                <input
                  type="number"
                  name="system.progress.abilities.{{ idx }}.xp"
                  value="{{ ability.xp }}"
                  hidden
                  data-dtype="Number"
                  data-index="{{ idx }}"
                  data-type="abilities"
                  class="progress-xp flex0"
                  style="width: 50px"
                  min="0"
                  step="1"
                />
                {{/unless}}
              </div>
              <div class="progress-controls">
                <a
                  data-action="progressControl"
                  data-subaction="delete"
                  data-idx="{{ idx }}"
                  data-type="abilities"
                >
                  <i class="ars-Icon_Delete_Hand_Gesture"></i>
                </a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
      </div>
      {{!-- {{log "ARTS TAB" }} --}}
      {{!-- Arts tab --}}
      <div
        class="tab{{#if subtabs.arts.active}} active{{/if}} item flexcol marginItemPart"
        data-tab="arts"
        data-group="advanced-secondary"
      >
        <header class="effect-change effects-header flexrow" style="padding-left: 15px">
          <div class="key">{{localize "arm5e.sheet.arts"}}</div>
          {{#if ui.showTeacher}}
          <div class="teacher-score">{{localize "arm5e.activity.teacher.score"}}</div>
          {{else}}
          <div class="xpamount">{{localize "arm5e.sheet.experience"}}</div>
          {{/if}}
          <div class="progress-controls">
            {{#unless system.canProgress.arts}}
            {{localize "arm5e.activity.msg.noArt"}}
            {{else}}
            <a
              data-action="progressControl"
              data-subaction="add"
              data-type="arts"
              data-default="{{ system.defaultArt }}"
              data-teacherscore="{{ system.teacher.score }}"
            >
              <i class="fas fa-plus"></i>
            </a>
            {{/unless}}
          </div>
        </header>
        <div class="resource">
          <ol class="progresses-list">
            {{#each system.progress.arts as |art idx|}}
            <li class="item diary-progress flexrow">
              <select
                name="system.progress.arts.{{ idx }}.key"
                data-dtype="String"
                data-index="{{ idx }}"
                data-type="arts"
                class="progress-art flex02"
                {{@root.system.disabled}}
                style="min-width: 150px"
              >
                {{selectOptions @root.system.ownedArts selected=art.key labelAttr="label" nameAttr="key" valueAttr="key"}}
              </select>
              <div class="xp">
                {{#unless ../ui.showTeacher}}
                <input
                  type="number"
                  name="system.progress.arts.{{ idx }}.xp"
                  value="{{ art.xp }}"
                  data-dtype="Number"
                  data-index="{{ idx }}"
                  data-type="arts"
                  {{@root.system.canEdit}}
                  class="progress-xp flex0 select-on-focus"
                  style="width: 50px"
                  min="0"
                  step="1"
                />
                {{else}}
                <input
                  type="number"
                  name="system.progress.arts.{{ idx }}.teacherScore"
                  value="{{ art.teacherScore }}"
                  data-dtype="Number"
                  data-index="{{ idx }}"
                  data-type="arts"
                  readonly
                  class="flex0"
                  style="width: 50px"
                  min="0"
                  step="1"
                />
                <input
                  type="number"
                  name="system.progress.arts.{{ idx }}.xp"
                  value="{{ art.xp }}"
                  data-dtype="Number"
                  data-index="{{ idx }}"
                  data-type="arts"
                  class="progress-xp flex0"
                  style="width: 50px; display: none"
                  min="0"
                  step="1"
                />
                {{/unless}}
              </div>
              <div class="progress-controls">
                <a
                  data-action="progressControl"
                  data-subaction="delete"
                  data-idx="{{ idx }}"
                  data-type="arts"
                >
                  <i class="ars-Icon_Delete_Hand_Gesture"></i>
                </a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
      </div>
      {{!-- {{log "MASTERIES TAB" }} --}}
      {{!-- Masteries tab --}}
      <div
        class="tab{{#if subtabs.masteries.active}} active{{/if}} item flexcol marginItemPart"
        data-tab="masteries"
        data-group="advanced-secondary"
      >
        <header class="effect-change effects-header flexrow" style="padding-left: 15px">
          <div class="form">{{localize "arm5e.sheet.form"}}</div>
          <div class="key" style="min-width: 200px">{{localize "arm5e.sheet.spell"}}</div>
          {{#if ui.showTeacher}}
          <div class="teacher-score">{{localize "arm5e.activity.teacher.score"}}</div>
          {{else}}
          <div class="xpamount">{{localize "arm5e.sheet.experience"}}</div>
          {{/if}}
          <div class="progress-controls">
            {{#unless system.canProgress.spells}}
            {{localize "arm5e.activity.msg.noSpell"}}
            {{else}}
            <a
              data-action="progressControl"
              data-subaction="add"
              data-type="spells"
              data-teacherscore="{{ system.teacher.score }}"
              data-default="{{ system.defaultSpellMastery }}"
            >
              <i class="fas fa-plus"></i>
            </a>
            {{/unless}}
          </div>
        </header>
        <div class="resource">
          <ol class="progresses-list">
            {{#each system.progress.spells as |spell idx|}}
            <li class="item diary-progress flexrow">
              <select
                name="system.progress.spells.{{ idx }}.form"
                data-dtype="String"
                data-index="{{ idx }}"
                data-type="spells"
                {{@root.system.disabled}}
                class="progress-category flex02"
                style="min-width: 135px"
              >
                {{selectOptions @root.system.ownedSpellForms selected=spell.form}}
              </select>
              <select
                name="system.progress.spells.{{ idx }}.id"
                data-dtype="String"
                data-index="{{ idx }}"
                data-type="spells"
                {{@root.system.disabled}}
                class="progress-spell flex02"
                style="min-width: 200px"
              >
                {{selectOptions (lookup ../system.ownedSpells spell.form) selected=spell.id labelAttr="label"
                nameAttr="id" valueAttr="id"}}
              </select>
              <div class="xp">
                {{#unless ../ui.showTeacher}}
                <input
                  type="number"
                  name="system.progress.spells.{{ idx }}.xp"
                  value="{{ spell.xp }}"
                  data-dtype="Number"
                  data-index="{{ idx }}"
                  data-type="spells"
                  {{@root.system.canEdit}}
                  class="progress-xp flex0 select-on-focus"
                  style="width: 50px"
                  min="0"
                  step="1"
                />
                {{else}}
                <input
                  type="number"
                  name="system.progress.spells.{{ idx }}.teacherScore"
                  value="{{ spell.teacherScore }}"
                  data-dtype="Number"
                  data-index="{{ idx }}"
                  data-type="spells"
                  readonly
                  class="flex0"
                  style="width: 50px"
                  min="0"
                  step="1"
                />
                <input
                  type="number"
                  name="system.progress.spells.{{ idx }}.xp"
                  value="{{ spell.xp }}"
                  data-dtype="Number"
                  hidden
                  data-index="{{ idx }}"
                  data-type="spells"
                  class="progress-xp flex0"
                  style="width: 50px; display: none"
                  min="0"
                  step="1"
                />
                {{/unless}}
              </div>
              <div class="progress-controls">
                <a
                  data-action="progressControl"
                  data-subaction="delete"
                  data-idx="{{ idx }}"
                  data-type="spells"
                >
                  <i class="ars-Icon_Delete_Hand_Gesture"></i>
                </a>
              </div>
            </li>
            {{/each}}
          </ol>
        </div>
      </div>

      {{!-- New Spells tab --}}
      {{!-- {{log "SPELLS TAB" }} --}}
      <div
        class="tab{{#if subtabs.spells.active}} active{{/if}} item flexcol marginItemPart"
        data-tab="spells"
        data-group="advanced-secondary"
      >
        <header class="effect-change effects-header flexrow" style="padding-left: 15px">
          <div class="key" style="min-width: 200px">{{localize "arm5e.sheet.spell"}}</div>
        </header>
        <div class="resource drop-newspell flexrow" data-drop="newspell" style="height: 170px">
          <div class="flex3">
            <ol class="progresses-list">
              {{#each system.progress.newSpells as |spell idx|}}
              <li class="item diary-progress flexrow">
                <div class="resource flexrow">
                  <label
                    for="system.progress.newSpells.{{ idx }}.name"
                    class=""
                    style="font-size: 9pt"
                    >{{ spell.label }}</label
                  >
                  <div class="flex01 flexrow">
                    <a
                      data-action="showSpell"
                      class="item-control flex0"
                      title="{{localize 'arm5e.generic.details'}}"
                      data-index="{{ idx }}"
                    >
                      <i class="ars-Icon_Read"></i>
                    </a>
                    <a
                      data-action="progressControl"
                      data-subaction="delete"
                      class="flex0"
                      data-idx="{{ idx }}"
                      data-type="newSpells"
                    >
                      <i class="ars-Icon_Delete_Hand_Gesture"></i>
                    </a>
                  </div>
                </div>
              </li>
              {{/each}}
            </ol>
          </div>
        </div>
      </div>
    </section>

    {{/if}}

    {{!-- Action buttons (apply / partial / rollback / roll / refresh) --}}
    <div class="flexrow" style="margin-top: 4px">
      {{!-- Partial progress button hidden: feature not yet finished
      {{#if partialButton}}
      {{#if rollNeeded}}
      <button class="arm5e flex03" data-action="rollActivity" style="font-family: bookAntika">
        {{localize rollLabel}}
      </button>
      {{else}}
      <button
        class="arm5e flex02"
        data-action="progressPartial"
        data-sourcemodifier="{{ system.sourceModifier }}"
        style="font-family: bookAntika"
      >
        {{localize "arm5e.sheet.action.partialProgress"}}
      </button>
      {{/if}}
      {{else}}
      --}}
      {{!-- always use the non-partial branch while feature is disabled --}}
      {{#if system.applyPossible}}
      {{#if rollNeeded}}
      <button class="arm5e flex03" data-action="rollActivity" style="font-family: bookAntika">
        {{localize rollLabel}}
      </button>
      {{else}}
      <button
        class="arm5e flex02"
        data-action="progressApply"
        data-sourcemodifier="{{ system.sourceModifier }}"
        style="font-family: bookAntika"
      >
        {{localize "arm5e.sheet.action.apply"}}
      </button>
      {{/if}}
      {{else}}
      {{#unless system.done}}
      <button class="arm5e flex02" data-action="progressRefresh" style="font-family: bookAntika">
        {{localize "arm5e.lab.planning.button.refresh"}}
      </button>
      {{else}}
      <button class="arm5e flex02" data-action="progressRollback" style="font-family: bookAntika">
        {{localize "arm5e.sheet.action.rollback"}}
      </button>
      {{/unless}}
      {{/if}}
      {{!-- {{/if}} ← was closing #if partialButton, removed while feature is disabled --}}
      <div class="flexcol">
        <label class="" style="color: red; padding: 10px">
          {{localize system.applyError param=system.errorParam}}
        </label>
        <label class="" style="padding: 10px">
          {{localize system.applyInfo param=system.infoParam}}
        </label>
      </div>
    </div>
  </div>
</div>
