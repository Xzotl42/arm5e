<div class='sheet-header-part'>
  <div class='header-background'>
    <img src='systems/arm5e/assets/item/{{ flavor }}_header.png' />
  </div>
  <header class='sheet-header marginItemPart'>
    <img
      class='item-img'
      src='{{ item.img }}'
      data-action='editImage'
      data-edit='img'
      data-tooltip="<img
      class='img-tooltip'
      src='{{ item.img }}'/>"
      data-tooltip-direction="CENTER"
      title='{{ item.name }}'
    />
    <div class='header-fields'>
      <h1 class='bigname'>
        <div class='flexrow'>
          <input name='name' type='text' value='{{ item.name }}' placeholder='Name' />
          {{#if isOwned}}
          <div class='flex0 padding10'>
            <a
              data-action='harvestVis'
              title='{{localize 'arm5e.sheet.visHarvest'}}'
              ><img
                class='clickable'
                src='systems/arm5e/assets/icons/sickle.svg'
                style='border: 0px; height: 18px; min-height: 30px; min-width: 30px'
            /></a>
          </div>
          {{/if}}
        </div>
      </h1>
      <div class='grid grid-2col'>
        <div class='resource flexcol'>
          <label>{{localize 'arm5e.sheet.art'}}</label>
          <select name='system.art' data-type='String'>
            {{selectOptions config.magic.arts selected=system.art labelAttr='label'}}
          </select>
        </div>
        <div class='resource flexcol'>
          <label>{{localize 'arm5e.sheet.season'}}</label>
          <select name='system.season' data-type='String'>
            {{selectOptions config.seasons selected=system.season labelAttr='label' localize=true}}
          </select>
        </div>
      </div>
      <div class='resource flexrow'>
        <div class='resource'>
          <label>{{localize 'arm5e.sheet.pawns'}}</label>
          <input
            type='number'
            class='modifier select-on-focus'
            name='system.pawns'
            value='{{ system.pawns }}'
            data-dtype='Number'
          />
        </div>
        <div class='resource'>
          <label>{{localize 'arm5e.sheet.visLabel'}}</label>
          <input type='text' name='system.visLabel' value='{{ system.visLabel }}' data-dtype='String' />
        </div>
      </div>
      <div class='resource'>
        <label>{{localize 'arm5e.sheet.location'}}</label>
        <input type='text' name='system.place' value='{{ system.place }}' data-dtype='String' />
      </div>
    </div>
  </header>
  <div class='marginItemPart'>{{> "systems/arm5e/templates/generic/metalic-bar.html" }}</div>
</div>
