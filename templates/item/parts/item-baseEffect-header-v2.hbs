<div class="sheet-header-part">
  <div class="header-background">
    <img src="{{systemPath}}assets/item/{{ flavor }}_header.png" />
  </div>
  <header class="sheet-header marginItemPart">
    <img
      class="item-img"
      src="{{ item.img }}"
      data-action="editImage"
      data-edit="img"
      data-tooltip="<img
      class='img-tooltip'
      src='{{ item.img }}'/>"
      data-tooltip-direction="CENTER"
      title="{{ item.name }}"
    />
    <div class="header-fields flexcol">
      <h1 class="bigname">
        <input
          name="name"
          type="text"
          value="{{ item.name }}"
          placeholder="Name"
          title="{{ item.name }}"
        />
      </h1>
      <div class="grid grid-2col">
        <div class="resource flexcol">
          <label>{{localize 'arm5e.sheet.technique'}}</label>
          <select name="system.technique.value" data-type="String">
            {{selectOptions config.magic.techniques selected=system.technique.value labelAttr='label'}}
          </select>
        </div>
        <div class="resource flexcol">
          <label>{{localize 'arm5e.sheet.form'}}</label>
          <select name="system.form.value" data-type="String" class="select-form">
            {{selectOptions config.magic.forms selected=system.form.value labelAttr='label'}}
          </select>
        </div>
      </div>
      <div class="flexrow">
        <div class="resource flexcol flex-center">
          <label>{{localize 'arm5e.spell.effect.baseLevel'}}</label>
          <input
            type="number"
            class="select-on-focus"
            name="system.baseLevel"
            value="{{ system.baseLevel }}"
            data-dtype="Number"
            style="max-width: 70px"
          />
        </div>
        <div class="resource flexcol flex-center">
          <label>{{localize 'arm5e.sheet.Requisites'}}</label>
          <a
            class="item-control"
            data-action="advancedReq"
            data-flavor="{{ flavor }}"
            title="{{localize 'arm5e.sheet.Requisites'}}"
            ><i class="fas fa-gavel fa-lg"></i
          ></a>
          <label class="label-light">{{ ui.requisites }}</label>
        </div>
      </div>
      <div class="resource">
        <label>{{localize 'arm5e.spell.effect.description'}}</label>
        <input
          type="text"
          name="system.baseEffectDescription"
          value="{{ system.baseEffectDescription }}"
          data-dtype="String"
        />
      </div>
    </div>
    {{#if editable}}
    <a data-action="itemDeleteConfirm" title="{{localize 'arm5e.hints.delete' item=item.name}}"
      ><i class="ars-Icon_Delete_Hand_Gesture item-delete-large"></i
    ></a>
    {{/if}}
  </header>
  <div class="marginItemPart">{{> (systemPath "templates/generic/metalic-bar.html") }}</div>
</div>
