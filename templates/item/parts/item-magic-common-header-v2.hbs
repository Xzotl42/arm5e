<div class="sheet-header-part">
  <div class="header-background">
    <img src="systems/arm5e/assets/item/{{ flavor }}_header.png" />
  </div>
  <header class="sheet-header marginItemPart">
    <img
      class="item-img"
      src="{{ item.img }}"
      data-action="editImage"
      data-edit="img"
      data-tooltip="<img
      class='img-tooltip'
      src='{{ item.img }}'/>"
      data-tooltip-direction="CENTER"
      title="{{ item.name }}"
    />
    <div class="header-fields flexcol">
      <h1 class="bigname">
        {{#if isCharacter}}
        <div class="flexrow">
          <input
            name="name"
            type="text"
            value="{{ item.name }}"
            title="{{ item.name }}"
            placeholder="Name"
          />
          {{#if (eq item.type 'spell')}}
          <div class="flex0 padding2">
            <a data-action="createLabText" title="{{localize 'arm5e.hints.createLabText'}}"
              ><i class="ars-Icon_Details2"></i
            ></a>
          </div>
          {{/if}}
          <div class="flex0 padding2">
            <a data-action="rollEffect" title="{{localize 'arm5e.dialog.button.roll'}}">
              <img
                src="systems/arm5e/assets/dice.png"
                style="border: 0; height: 30px; min-height: 30px; min-width: 30px"
              />
            </a>
          </div>
          {{#if editable}}
          <div class="flex0 padding2">
            <a
              data-action="itemDeleteConfirm"
              title="{{localize 'arm5e.hints.delete' item=item.name}}"
              ><i class="ars-Icon_Delete_Hand_Gesture item-delete-large"></i
            ></a>
          </div>
          {{/if}}
        </div>
        {{else}}
        <input
          name="name"
          type="text"
          value="{{ item.name }}"
          title="{{ item.name }}"
          placeholder="Name"
        />
        {{/if}}
      </h1>
      {{#if locked}}<i class="ars-Icon_Locked"></i>{{/if}}
      <div class="grid grid-2col">
        <div class="resource flexcol">
          <label>{{localize 'arm5e.sheet.technique'}}</label>
          <select name="system.technique.value" data-type="String" {{noSelect}}>
            {{selectOptions config.magic.techniques selected=system.technique.value labelAttr='label'}}
          </select>
        </div>
        <div class="resource flexcol">
          <label>{{localize 'arm5e.sheet.form'}}</label>
          <select name="system.form.value" data-type="String" class="select-form" {{noSelect}}>
            {{selectOptions config.magic.forms selected=system.form.value labelAttr='label'}}
          </select>
        </div>
      </div>
      <div class="flexrow">
        <div class="resource flexcol flex-center">
          <label>{{localize 'arm5e.sheet.Requisites'}}</label>
          <label class="label-light">{{ ui.requisites }}</label>
          <a
            class="item-control"
            data-action="advancedReq"
            data-flavor="{{ flavor }}"
            title="Advanced Requisites"
            ><i class="fas fa-gavel fa-lg"></i
          ></a>
        </div>
        {{#if (eq item.type 'spell')}}
        <div class="resource flexcol flex-center">
          <label>{{localize 'arm5e.sheet.ritual'}}</label>
          <input type="checkbox" name="system.ritual" {{checked system.ritual}} {{noSelect}} />
        </div>
        {{/if}}
        <div class="resource flexcol flex-center">
          <label>{{localize 'arm5e.sheet.level'}}</label>
          <input
            class="design-level"
            type="number"
            readonly
            name="system.level"
            value="{{ system.level }}"
            data-dtype="Number"
            style="max-width: 60px"
          />
        </div>
      </div>
    </div>
  </header>
  <div class="marginItemPart">{{> "systems/arm5e/templates/generic/metalic-bar.html" }}</div>
</div>
